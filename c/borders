#define ADD_CLAMP(var, by) { unsigned long _by = (by); var += _by; if (var>255) var=255; }

#define SCI_FI_R     (12)
#define BORDER_WIDTH (2)
#define BORDER_INSET (6)
#define MIN_WIDTH    (80)

/*************************************************** Gerph *********
 Function:     mix
 Description:  Mix two colours with a given ratio
 Parameters:   col1, col2 = colours to mix
               ratio = 0..256 (256 = all col1)
 Returns:      mixed colour
 ******************************************************************/
static unsigned long mix(unsigned long col1, unsigned long col2, int ratio)
{
  unsigned long r, g, b;
  r = (((col1 & 0x0000FF00) >> 8) * ratio + ((col2 & 0x0000FF00) >> 8) * (256 - ratio)) >> 8;
  g = (((col1 & 0x00FF0000) >> 16) * ratio + ((col2 & 0x00FF0000) >> 16) * (256 - ratio)) >> 8;
  b = (((col1 & 0xFF000000) >> 24) * ratio + ((col2 & 0xFF000000) >> 24) * (256 - ratio)) >> 8;
  return (r << 8) | (g << 16) | (b << 24);
}

/*************************************************** Gerph *********
 Function:     draw_scifi_outline
 Description:  Draw the outline of a scifi button
 Parameters:   x0,y0,x1,y1 = box
               r = corner radius
               col = colour
 Returns:      none
 ******************************************************************/
static void draw_scifi_outline(int x0, int y0, int x1, int y1, int r, unsigned long col)
{
  gcol(col);
  move(x0 + r, y0);
  draw(x1 - r, y0);
  draw(x1, y0 + r);
  draw(x1, y1 - r);
  draw(x1 - r, y1);
  draw(x0 + r, y1);
  draw(x0, y1 - r);
  draw(x0, y0 + r);
  draw(x0 + r, y0);
}

/*************************************************** Gerph *********
 Function:     draw_fancy_scifi
 Description:  Draw a fancy scifi button with glow and flourishes
 Parameters:   x0,y0,x1,y1 = box
               r = corner radius
               col = colour
 Returns:      none
 ******************************************************************/
static void draw_fancy_scifi(int x0, int y0, int x1, int y1, int r, unsigned long col)
{
  unsigned long glow1 = (col >> 1) & 0x7F7F7F00;
  unsigned long glow2 = (col >> 2) & 0x3F3F3F00;
  
  /* Inner depth glow (instead of outer shadow) */
  draw_scifi_outline(x0 + 1, y0 + 1, x1 - 1, y1 - 1, r - 1, glow2);

  /* Outer glow layers - very tight to avoid washing out */
  draw_scifi_outline(x0 - 2, y0 - 2, x1 + 2, y1 + 2, r + 1, glow2);
  draw_scifi_outline(x0 - 1, y0 - 1, x1 + 1, y1 + 1, r, glow1);
  
  /* Main border */
  draw_scifi_outline(x0, y0, x1, y1, r, col);
  
  /* Corner brackets - technical flourishes */
  gcol(col);
  /* Top-left bracket */
  line(x0 - 6, y1 - r, x0 - 6, y1 + 6); 
  line(x0 - 6, y1 + 6, x0 + r, y1 + 6);
  /* Bottom-right bracket */
  line(x1 + 6, y0 + r, x1 + 6, y0 - 6);
  line(x1 + 6, y0 - 6, x1 - r, y0 - 6);

  /* Active indicator dot - makes it look "powered on" */
  gcol(0xFFFFFF00);
  point(x0 - 6, y1 + 6);
  point(x1 + 6, y0 - 6);

  /* Side detail bars */
  gcol(glow1);
  line(x0 - 4, y0 + r + 8, x0 - 4, y1 - r - 8);
  line(x1 + 4, y0 + r + 8, x1 + 4, y1 - r - 8);
}

/*************************************************** Gerph *********
 Function:     fill_scifi_core
 Description:  Fill a scifi button background (foreground color)
 Parameters:   x0,y0,x1,y1 = box
               r = corner radius
 Returns:      none
 ******************************************************************/
static void fill_scifi_core(int x0, int y0, int x1, int y1, int r)
{
  if (x1 <= x0 || y1 <= y0) return;

  /* Central rectangle */
  rect(x0 + r, y0, x1 - r, y1);
  /* Left side */
  rect(x0, y0 + r, x0 + r, y1 - r);
  /* Right side */
  rect(x1 - r, y0 + r, x1, y1 - r);

  /* Top-left triangle */
  move(x0, y1 - r);
  move(x0 + r, y1);
  _swix(OS_Plot, _INR(0, 2), 0x50 | 5, x0 + r, y1 - r);

  /* Top-right triangle */
  move(x1 - r, y1);
  move(x1, y1 - r);
  _swix(OS_Plot, _INR(0, 2), 0x50 | 5, x1 - r, y1 - r);

  /* Bottom-left triangle */
  move(x0, y0 + r);
  move(x0 + r, y0);
  _swix(OS_Plot, _INR(0, 2), 0x50 | 5, x0 + r, y0 + r);

  /* Bottom-right triangle */
  move(x1, y0 + r);
  move(x1 - r, y0);
  _swix(OS_Plot, _INR(0, 2), 0x50 | 5, x1 - r, y0 + r);
}

/*************************************************** Gerph *********
 Function:     bright
 Description:  Make a colour brighter
 Parameters:   col = the colour to make brighter
 Returns:      none
 ******************************************************************/
static unsigned long bright(unsigned long col)
{
  unsigned long r, g, b;
  r = (col & 0x0000FF00) >> 8;
  g = (col & 0x00FF0000) >> 16;
  b = (col & 0xFF000000) >> 24;

  ADD_CLAMP(r, 0x10); /* Keep red low to maintain tech cyan feel */
  ADD_CLAMP(g, 0x60);
  ADD_CLAMP(b, 0x60);
  return (r << 8) | (g << 16) | (b << 24);
}

/*************************************************** Gerph *********
 Function:     fill_scifi_fancy
 Description:  Fill a scifi button with fading gradient and hatching
 Parameters:   x0,y0,x1,y1 = box
               r = corner radius
               bg = background colour
               mind = pixel size
 Returns:      none
 ******************************************************************/
static void fill_scifi_fancy(int x0, int y0, int x1, int y1, int r, unsigned long bg, int mind)
{
  int i;
  int grid = 12;
  int delta;
  unsigned long cur_bg = bg;
  
  /* Draw concentric layers to simulate a fade from dark edges to lighter center */
  for (i = 0; i < 6; i++)
  {
    unsigned long next_r, next_g, next_b;
    gcol(cur_bg);
    fill_scifi_core(x0 + i, y0 + i, x1 - i, y1 - i, r - i > 0 ? r - i : 0);
    
    /* Subtle brightening for the next layer - primarily Cyan */
    next_r = (cur_bg & 0x0000FF00) >> 8;
    next_g = (cur_bg & 0x00FF0000) >> 16;
    next_b = (cur_bg & 0xFF000000) >> 24;
    next_r = (next_r + 2 > 255) ? 255 : next_r + 2;
    next_g = (next_g + 8 > 255) ? 255 : next_g + 8;
    next_b = (next_b + 8 > 255) ? 255 : next_b + 8;
    cur_bg = (next_r << 8) | (next_g << 16) | (next_b << 24);
  }
  
  /* Top Gloss effect - 4 layers for blending */
  for (i = 0; i < 4; i++)
  {
    unsigned long gloss_col;
    unsigned long gr = (bg & 0x0000FF00) >> 8;
    unsigned long gg = (bg & 0x00FF0000) >> 16;
    unsigned long gb = (bg & 0xFF000000) >> 24;
    int strength = (4 - i) * 24;
    int ty1, ty0;
    
    /* Stronger at top, fading down */
    ADD_CLAMP(gr, strength);
    ADD_CLAMP(gg, strength + 32);
    ADD_CLAMP(gb, strength + 32);
    gloss_col = (gr << 8) | (gg << 16) | (gb << 24);
    
    gcol(gloss_col);
    /* y1+1 is the original snapped top. mind is pixel size. */
    ty1 = (y1 + 1) - i * mind - 1;
    ty0 = ty1 - (mind - 1);
    rect(x0 + r, ty0, x1 - r, ty1);
  }

  /* Diagonal tech hatching */
  gcol((bg >> 1) & 0x7F7F7F00);
  delta = (y1 - y0);
  delta &= ~(mind - 1); /* Perfect 45 degree slope for pixel ratio */
  for (i = - delta; i < (x1 - x0); i += grid)
  {
    int lx0 = x0 + i;
    int ly0 = y0;
    int lx1 = lx0 + delta;
    int ly1 = ly0 + delta;
    
    /* Clipping to the main button area (roughly) */
    if (lx0 < x0 + r) { ly0 += (x0 + r - lx0); lx0 = x0 + r; }
    if (lx1 > x1 - r) { ly1 -= (lx1 - (x1 - r)); lx1 = x1 - r; }
    
    if (lx0 < x1 - r && lx1 > x0 + r && ly1 > ly0)
      line(lx0, ly0, lx1, ly1);
  }
}



/*************************************************** Gerph *********
 Function:     border_draw
 Description:  Draw a border
 Parameters:   type = button type
               flags = button flags
               box-> the bounding box to use
               colours-> the colours we're using
               ditherflags = flags to use for dithering
 Returns:      1 if handled, 0 if not handled
 ******************************************************************/
int border_draw(int type, unsigned long flags,
                 bbox_t *box, colours_t *colours,
                 unsigned long ditherflags)
{
  if ((type == 5 || type == 6) && box->x1 - box->x0 > MIN_WIDTH)
  {
    int x0, y0, x1, y1;
    int r = SCI_FI_R;

    /* Snapcoords */
    x0 = box->x0 & ~box->dx_1;
    x1 = box->x1 & ~box->dx_1;
    y0 = box->y0 & ~box->dy_1;
    y1 = box->y1 & ~box->dy_1;

    y1 -= 1;
    x1 -= 1;

    if (type == 6)
    {
      x1 -= 8; x0 += 8;
      y1 -= 8; y0 += 8;
    }

    if (flags & (1 << 21))
    {
      /* Pressed effect: shift 2 units */
      x0 += 2; x1 += 2;
      y0 -= 2; y1 -= 2;
    }

    if (type == 6)
    {
      draw_fancy_scifi(x0, y0, x1, y1, r, colours[COLOUR_WELL]);
    }
    else
    {
      unsigned long glow1 = (colours[COLOUR_WELL] >> 1) & 0x7F7F7F00;
      draw_scifi_outline(x0, y0, x1, y1, r, colours[COLOUR_WELL]);
      draw_scifi_outline(x0 + 1, y0 + 1, x1 - 1, y1 - 1, r - 1, glow1);
    }

    if (flags & (1 << 23))
    {
      /* Highlight pulse line */
      gcol(0xFFFFFF00);
      line(x0 + r, y1 - 2, x1 - r, y1 - 2);
    }

    return 1;
  }

  return 0;
}

/*************************************************** Gerph *********
 Function:     border_fill
 Description:  Fill the inner section of a bordered region
 Parameters:   type = button type
               flags = button flags
               box-> the bounding box to use
               colours-> the colours in use
 Returns:      1 if handled, 0 if not handled
 ******************************************************************/
int border_fill(int type, unsigned long flags, bbox_t *box,
                colours_t *colours, unsigned long ditherflags)
{
  if ((type == 5 || type == 6) && box->x1 - box->x0 > MIN_WIDTH)
  {
    int x0, y0, x1, y1;
    int r = SCI_FI_R;
    int mind = (box->dx < box->dy) ? box->dx : box->dy;

    /* Snapcoords */
    x0 = box->x0 & ~box->dx_1;
    x1 = box->x1 & ~box->dx_1;
    y0 = box->y0 & ~box->dy_1;
    y1 = box->y1 & ~box->dy_1;

    y1 -= 1;
    x1 -= 1;

    if (type == 6)
    {
      x1 -= 8; x0 += 8;
      y1 -= 8; y0 += 8;
    }

    if (flags & (1 << 21))
    {
      /* Pressed effect: shift 2 units */
      x0 += 2; x1 += 2;
      y0 -= 2; y1 -= 2;
    }

    fill_scifi_fancy(x0, y0, x1, y1, r, colours[COLOUR_BG], mind);
    return 1;
  }
  return 0;
}




/*************************************************** Gerph *********
 Function:     border_colour
 Description:  Set up the colour block with the correct colours
 Parameters:   type = button type
               flags = icon flags
               box-> bounding box
               cols-> the colour block to update
               background = window background colour
 Returns:      1 if handled, 0 if not handled
 ******************************************************************/
int border_colour(int type, unsigned long flags, bbox_t *box,
                  colours_t *cols, unsigned long background)
{
  if ((type == 5 || type == 6) && box->x1 - box->x0 > MIN_WIDTH)
  {
    /* SciFi style: Neon Cyan border, Dark background (strictly blue/green range) */
    cols[COLOUR_WELL] = 0xFFFF0000; /* Pure Neon Cyan (Blue=FF, Green=FF, Red=00) */
    
    /* Mix a dark midnight blue with the window background for a tinted glass effect */
    cols[COLOUR_BG]   = mix(0x11110000, background, 200);
    
    cols[COLOUR_FG]   = 0xFFFFFF00; /* White text */

    if (flags & (1 << 21))
    {
      /* Selected state: Glowing cyan background */
      cols[COLOUR_WELL] = 0xFFFFFF00; /* White border for high contrast */
      cols[COLOUR_BG]   = 0xCCAA0000; /* Vibrant Cyan-blue background */
      cols[COLOUR_FG]   = 0x00000000; /* Black text */
    }

    if (flags & (1 << 23))
    {
      /* Highlighted state: even brighter border */
      cols[COLOUR_WELL] = 0xFFFF2200; /* Slightly lighter neon cyan */
      cols[COLOUR_BG]   = bright(cols[COLOUR_BG]);
    }

    return 1;
  }
  return 0;
}



/*************************************************** Gerph *********
 Function:     border_size
 Description:  Return the size of a border
 Parameters:   type = button type
               flags = button flags
               box-> the bounding box to use
 Returns:      1 if handled, 0 if not handled
 ******************************************************************/
int border_size(int type, unsigned long flags, bbox_t *box)
{
  if ((type == 5 || type == 6) && box->x1 - box->x0 > MIN_WIDTH)
  {
    int r = SCI_FI_R;

    if (type == 6)
    {
      box->x1 -= 8; box->x0 += 8;
      box->y1 -= 8; box->y0 += 8;
    }

    if (flags & (1 << 21))
    {
      /* Shift text area too */
      box->x0 += 2; box->x1 += 2;
      box->y0 -= 2; box->y1 -= 2;
    }

    box->x0 += r + 4;
    box->x1 -= r + 4;
    box->y0 += 4;
    box->y1 -= 4;
    return 1;
  }
  return 0;
}



/*************************************************** Gerph *********
 Function:     border_state
 Description:  Return the state of the border renderer
 Parameters:   type = button type
               flags = button flags
               box-> the bounding box to use
 Returns:      our state flags for rendering
 ******************************************************************/
unsigned long border_state(int type, unsigned long flags, bbox_t *box)
{
  /* We need to return state flags to indicate what sort of button we provide
     in order that the Wimp can decide what to do about it. */

  if ((type==5 || type==6) && box->x1-box->x0 > MIN_WIDTH)
    return STATE_HIGHLIGHTABLE;
  return 0;
}
