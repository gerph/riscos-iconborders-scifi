#include <string.h>
#include "swis.h"
#include "borders.h"
#include "graphics.h"

#define SCI_FI_R     (12)
#define BORDER_WIDTH (2)
#define BORDER_INSET (6)
#define MIN_WIDTH    (80)

/*************************************************** Gerph *********
 Function:     draw_scifi_outline
 Description:  Draw the outline of a scifi button
 Parameters:   x0,y0,x1,y1 = box
               r = corner radius
               col = colour
 Returns:      none
 ******************************************************************/
static void draw_scifi_outline(int x0, int y0, int x1, int y1, int r, unsigned long col)
{
  gcol(col);
  move(x0 + r, y0);
  draw(x1 - r, y0);
  draw(x1, y0 + r);
  draw(x1, y1 - r);
  draw(x1 - r, y1);
  draw(x0 + r, y1);
  draw(x0, y1 - r);
  draw(x0, y0 + r);
  draw(x0 + r, y0);
}

/*************************************************** Gerph *********
 Function:     draw_fancy_scifi
 Description:  Draw a fancy scifi button with glow and brackets
 Parameters:   x0,y0,x1,y1 = box
               r = corner radius
               col = colour
 Returns:      none
 ******************************************************************/
static void draw_fancy_scifi(int x0, int y0, int x1, int y1, int r, unsigned long col)
{
  unsigned long glow = (col >> 1) & 0x7F7F7F00;
  
  /* Outer glow */
  draw_scifi_outline(x0 - 2, y0 - 2, x1 + 2, y1 + 2, r + 1, glow);
  
  /* Main border */
  draw_scifi_outline(x0, y0, x1, y1, r, col);
  
  /* Inner glow */
  draw_scifi_outline(x0 + 2, y0 + 2, x1 - 2, y1 - 2, r - 1, glow);

  /* Corner brackets - just top-left and bottom-right for sci-fi asymmetry */
  gcol(col);
  line(x0 - 4, y1 - r - 8, x0 - 4, y1 - r + 4); 
  line(x0 - 4, y1 - r + 4, x0 + r - 4, y1 + 4);
  line(x0 + r - 4, y1 + 4, x0 + r + 8, y1 + 4);

  line(x1 + 4, y0 + r + 8, x1 + 4, y0 + r - 4);
  line(x1 + 4, y0 + r - 4, x1 - r + 4, y0 - 4);
  line(x1 - r + 4, y0 - 4, x1 - r - 8, y0 - 4);
}

/*************************************************** Gerph *********
 Function:     fill_scifi_core
 Description:  Fill a scifi button background (foreground color)
 Parameters:   x0,y0,x1,y1 = box
               r = corner radius
 Returns:      none
 ******************************************************************/
static void fill_scifi_core(int x0, int y0, int x1, int y1, int r)
{
  /* Central rectangle */
  rect(x0 + r, y0, x1 - r, y1);
  /* Left side */
  rect(x0, y0 + r, x0 + r, y1 - r);
  /* Right side */
  rect(x1 - r, y0 + r, x1, y1 - r);

  /* Top-left triangle */
  move(x0, y1 - r);
  move(x0 + r, y1);
  _swix(OS_Plot, _INR(0, 2), 0x50 | 5, x0 + r, y1 - r);

  /* Top-right triangle */
  move(x1 - r, y1);
  move(x1, y1 - r);
  _swix(OS_Plot, _INR(0, 2), 0x50 | 5, x1 - r, y1 - r);

  /* Bottom-left triangle */
  move(x0, y0 + r);
  move(x0 + r, y0);
  _swix(OS_Plot, _INR(0, 2), 0x50 | 5, x0 + r, y0 + r);

  /* Bottom-right triangle */
  move(x1, y0 + r);
  move(x1 - r, y0);
  _swix(OS_Plot, _INR(0, 2), 0x50 | 5, x1 - r, y0 + r);
}

/*************************************************** Gerph *********
 Function:     bright
 Description:  Make a colour brighter
 Parameters:   col = the colour to make brighter
 Returns:      none
 ******************************************************************/
static unsigned long bright(unsigned long col)
{
  unsigned long r, g, b;
  r = (col & 0x0000FF00) >> 8;
  g = (col & 0x00FF0000) >> 16;
  b = (col & 0xFF000000) >> 24;

#define ADD_CLAMP(var, by) var += by; if (var>255) var=255;
  ADD_CLAMP(r, 0x60);
  ADD_CLAMP(g, 0x60);
  ADD_CLAMP(b, 0x60);
  return (r << 8) | (g << 16) | (b << 24);
}

/*************************************************** Gerph *********
 Function:     fill_scifi_fancy
 Description:  Fill a scifi button with banded gradient effect
 Parameters:   x0,y0,x1,y1 = box
               r = corner radius
               bg = background colour
 Returns:      none
 ******************************************************************/
static void fill_scifi_fancy(int x0, int y0, int x1, int y1, int r, unsigned long bg)
{
  unsigned long bg_light = bright(bg);
  unsigned long bg_dark = (bg >> 1) & 0x7F7F7F00;
  
  /* Base */
  gcol(bg);
  fill_scifi_core(x0, y0, x1, y1, r);
  
  /* Top band */
  gcol(bg_light);
  rect(x0 + r, y1 - 4, x1 - r, y1 - 1);
  
  /* Bottom band */
  gcol(bg_dark);
  rect(x0 + r, y0 + 1, x1 - r, y0 + 4);
}

/*************************************************** Gerph *********
 Function:     border_draw
 Description:  Draw a border
 Parameters:   type = button type
               flags = button flags
               box-> the bounding box to use
               colours-> the colours we're using
               ditherflags = flags to use for dithering
 Returns:      1 if handled, 0 if not handled
 ******************************************************************/
int border_draw(int type, unsigned long flags,
                 bbox_t *box, colours_t *colours,
                 unsigned long ditherflags)
{
  if ((type == 5 || type == 6) && box->x1 - box->x0 > MIN_WIDTH)
  {
    int x0, y0, x1, y1;
    int r = SCI_FI_R;

    /* Snapcoords */
    x0 = box->x0 & ~box->dx_1;
    x1 = box->x1 & ~box->dx_1;
    y0 = box->y0 & ~box->dy_1;
    y1 = box->y1 & ~box->dy_1;

    y1 -= 1;
    x1 -= 1;

    if (type == 6)
    {
      x1 -= 8; x0 += 8;
      y1 -= 8; y0 += 8;
    }

    if (flags & (1 << 21))
    {
      /* Pressed effect: shift 2 units */
      x0 += 2; x1 += 2;
      y0 -= 2; y1 -= 2;
    }

    if (type == 5)
    {
      draw_fancy_scifi(x0, y0, x1, y1, r, colours[COLOUR_WELL]);
    }
    else
    {
      draw_scifi_outline(x0, y0, x1, y1, r, colours[COLOUR_WELL]);
      draw_scifi_outline(x0 + 1, y0 + 1, x1 - 1, y1 - 1, r - 1, (colours[COLOUR_WELL] >> 1) & 0x7F7F7F00);
    }

    if (flags & (1 << 23))
    {
      /* Highlight pulse line */
      gcol(0xFFFFFF00);
      line(x0 + r, y1 - 2, x1 - r, y1 - 2);
    }

    return 1;
  }

  return 0;
}

/*************************************************** Gerph *********
 Function:     border_fill
 Description:  Fill the inner section of a bordered region
 Parameters:   type = button type
               flags = button flags
               box-> the bounding box to use
               colours-> the colours in use
 Returns:      1 if handled, 0 if not handled
 ******************************************************************/
int border_fill(int type, unsigned long flags, bbox_t *box,
                colours_t *colours, unsigned long ditherflags)
{
  if ((type == 5 || type == 6) && box->x1 - box->x0 > MIN_WIDTH)
  {
    int x0, y0, x1, y1;
    int r = SCI_FI_R;

    /* Snapcoords */
    x0 = box->x0 & ~box->dx_1;
    x1 = box->x1 & ~box->dx_1;
    y0 = box->y0 & ~box->dy_1;
    y1 = box->y1 & ~box->dy_1;

    y1 -= 1;
    x1 -= 1;

    if (type == 6)
    {
      x1 -= 8; x0 += 8;
      y1 -= 8; y0 += 8;
    }

    if (flags & (1 << 21))
    {
      /* Pressed effect: shift 2 units */
      x0 += 2; x1 += 2;
      y0 -= 2; y1 -= 2;
    }

    fill_scifi_fancy(x0, y0, x1, y1, r, colours[COLOUR_BG]);
    return 1;
  }
  return 0;
}



/*************************************************** Gerph *********
 Function:     border_colour
 Description:  Set up the colour block with the correct colours
 Parameters:   type = button type
               flags = icon flags
               box-> bounding box
               cols-> the colour block to update
               background = window background colour
 Returns:      1 if handled, 0 if not handled
 ******************************************************************/
int border_colour(int type, unsigned long flags, bbox_t *box,
                  colours_t *cols, unsigned long background)
{
  if ((type == 5 || type == 6) && box->x1 - box->x0 > MIN_WIDTH)
  {
    /* SciFi style: Neon Cyan border, Dark background */
    cols[COLOUR_WELL] = 0xEEEE0000; /* Bright Neon Cyan */
    cols[COLOUR_BG]   = 0x33111100; /* Very Dark Blue-Grey */
    cols[COLOUR_FG]   = 0xFFFFFF00; /* White text */

    if (flags & (1 << 21))
    {
      /* Selected state: Glowing cyan background */
      cols[COLOUR_WELL] = 0xFFFFFF00; /* White border for high contrast */
      cols[COLOUR_BG]   = 0xAA666600; /* Glowing cyan-ish background */
      cols[COLOUR_FG]   = 0x00000000; /* Black text */
    }

    if (flags & (1 << 23))
    {
      /* Highlighted state: even brighter */
      cols[COLOUR_WELL] = 0xFFFF0000; /* Maximum Neon Cyan */
      cols[COLOUR_BG]   = bright(cols[COLOUR_BG]);
    }

    return 1;
  }
  return 0;
}


/*************************************************** Gerph *********
 Function:     border_size
 Description:  Return the size of a border
 Parameters:   type = button type
               flags = button flags
               box-> the bounding box to use
 Returns:      1 if handled, 0 if not handled
 ******************************************************************/
int border_size(int type, unsigned long flags, bbox_t *box)
{
  if ((type == 5 || type == 6) && box->x1 - box->x0 > MIN_WIDTH)
  {
    int r = SCI_FI_R;

    if (type == 6)
    {
      box->x1 -= 8; box->x0 += 8;
      box->y1 -= 8; box->y0 += 8;
    }

    if (flags & (1 << 21))
    {
      /* Shift text area too */
      box->x0 += 2; box->x1 += 2;
      box->y0 -= 2; box->y1 -= 2;
    }

    box->x0 += r + 4;
    box->x1 -= r + 4;
    box->y0 += 4;
    box->y1 -= 4;
    return 1;
  }
  return 0;
}



/*************************************************** Gerph *********
 Function:     border_state
 Description:  Return the state of the border renderer
 Parameters:   type = button type
               flags = button flags
               box-> the bounding box to use
 Returns:      our state flags for rendering
 ******************************************************************/
unsigned long border_state(int type, unsigned long flags, bbox_t *box)
{
  /* We need to return state flags to indicate what sort of button we provide
     in order that the Wimp can decide what to do about it. */

  if ((type==5 || type==6) && box->x1-box->x0 > MIN_WIDTH)
    return STATE_HIGHLIGHTABLE;
  return 0;
}
